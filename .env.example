# OPENAI_API_KEY: Required for OpenAI API calls (GPT-4o, vision, etc.)
# Used server-side only via the Express backend — never expose to frontend.
OPENAI_API_KEY="your-openai-api-key"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE
# Create a project at https://supabase.com/dashboard/
# Find these in Project Settings -> API
VITE_SUPABASE_URL="your-project-url"
VITE_SUPABASE_ANON_KEY="your-anon-key"
